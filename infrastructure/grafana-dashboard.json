      "targets": [
        {
          "query": "import \"math\"\n\ntemp = from(bucket: \"climate\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"temp\")\n  |> filter(fn: (r) => r.room == \"${room}\")\n\nhum = from(bucket: \"climate\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"humidity\")\n  |> filter(fn: (r) => r.room == \"${room}\")\n\njoin(tables: {temp: temp, hum: hum}, on: [\"_time\", \"room\"])\n  |> map(fn: (r) => {\n    a = 17.62\n    b = 243.12\n    alpha = (a * r._value_temp) / (b + r._value_temp) + math.log(x: r._value_hum / 100.0)\n    taupunkt = (b * alpha) / (a - alpha)\n    abstand = r._value_temp - taupunkt\n    return {\n        _time: r._time,\n        _value: abstand,\n        _field: \"abstand_taupunkt\",\n        _measurement: \"taupunkt\",\n        room: r.room\n    }\n})",
          "refId": "A"
        }
      ],
      "title": "Schimmelrisiko",
